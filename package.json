{
  "name": "expat-wasm-dom",
  "version": "2.0.1",
  "description": "Document Object Model for expat-wasm",
  "main": "lib/index.js",
  "type": "module",
  "types": "types/index.d.ts",
  "files": [
    "lib/",
    "types"
  ],
  "scripts": {
    "pretest": "npm run grammar",
    "test": "c8 ava test",
    "grammar": "peggy --format es lib/xpathPattern3.pegjs",
    "lint": "eslint",
    "docs": "typedoc",
    "types": "tsc",
    "build": "npm run grammar && npm run types && npm test && npm run docs && npm run lint"
  },
  "workspaces": [
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hildjj/expat-wasm-dom.git"
  },
  "keywords": [
    "xml",
    "parse",
    "dom",
    "xpath",
    "wasm"
  ],
  "author": "Joe Hildebrand <joe-github@cursive.net>",
  "license": "MIT",
  "dependencies": {
    "@cto.af/linewrap": "4.0.1",
    "expat-wasm": "4.0.5"
  },
  "devDependencies": {
    "@cto.af/eslint-config": "^6.2.5",
    "@types/node": "^25.5.0",
    "ava": "^7.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "peggy": "^5.1.0",
    "superc8": "^12.3.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1"
}
